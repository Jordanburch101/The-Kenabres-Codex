---
// Temporary home page (Phase 2 will replace this with the full directory:
// cards, filters, search). For now, a simple styled list of the 6 builds
// plus a link into the auto-generated Codex index.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const builds = (await getCollection('builds'))
  .map((b) => b.data)
  .sort((a, b) => a.name.localeCompare(b.name));

const KIND_LABEL: Record<string, string> = { mc: 'MC', companion: 'Companion', mercenary: 'Mercenary' };
const kindLabel = (k: string) => KIND_LABEL[k] ?? (k.charAt(0).toUpperCase() + k.slice(1));
---
<Base title="The Kenabres Codex">
  <main class="content"><div class="wrap">
    <div class="hero">
      <p class="eyebrow">Pathfinder: Wrath of the Righteous</p>
      <h1 class="btitle">The Kenabres Codex</h1>
      <p class="dim">Companion and mercenary build guides, forged in the ashes of the Worldwound.</p>
    </div>

    <section class="blk">
      <p class="eyebrow">Builds</p>
      <h2 class="h">Choose Your Champion</h2>
      <div class="rows">
        {builds.map((b) => (
          <a class="row build-row" href={`/builds/${b.slug}`}>
            <span class="k">{b.name}</span>
            <span class="v">
              {b.role}
              {b.class && ` — ${b.class}${b.archetype ? ` (${b.archetype})` : ''}`}
              <span class="dim"> · {kindLabel(b.kind)}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <p class="dim" style="margin-top: 32px;">
      <a href="/codex">Browse the Codex — every feat, spell &amp; mechanic referenced across these builds →</a>
    </p>
  </div></main>
</Base>

<style>
  .build-row { text-decoration: none; color: inherit; transition: background .12s ease; }
  .build-row:hover { background: rgba(120, 92, 50, .14); }
  .build-row:hover .k { color: var(--wine); }
</style>
