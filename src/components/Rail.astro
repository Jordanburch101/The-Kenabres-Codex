---
import { getCollection } from 'astro:content';
import RailNav from './RailNav';
import type { SectionRef } from '../lib/sections';
import type { RailBuild } from '../lib/rail';

interface Props {
  activeSlug?: string;
  sections?: SectionRef[];
}
const { activeSlug, sections = [] } = Astro.props;

const builds: RailBuild[] = (await getCollection('builds')).map((b) => ({
  slug: b.data.slug,
  name: b.data.name,
  kind: b.data.kind,
  class: b.data.class,
  role: b.data.role,
  featured: b.data.featured,
}));
---
<aside class="rail" aria-label="Party builds">
  <div class="rail-head">
    <p class="rail-kicker">Pathfinder · WOTR</p>
    <p class="rail-title">Kenabres Codex</p>
    <div class="rail-rule"></div>
  </div>

  {sections.length > 0 && (
    <nav class="rail-list rail-onpage rail-onpage--top">
      <div class="rail-div">On this page</div>
      <div class="rail-toc">
        {sections.map((s) => (
          <a class="rail-sec" href={`#${s.id}`}>{s.label}</a>
        ))}
      </div>
    </nav>
  )}

  <RailNav client:load builds={builds} activeSlug={activeSlug} />

  <nav class="rail-list">
    <div class="rail-div">Reference</div>
    <a class="nav" href="/codex">
      <span class="nav-name">The Codex</span>
      <span class="nav-role">Feats · Spells · Mechanics</span>
    </a>
  </nav>
</aside>

<script>
  // Scroll-spy: highlight the "On this page" link for the section you're reading —
  // the last section whose top has scrolled above a line near the viewport top.
  const links = [...document.querySelectorAll('.rail-toc a[href^="#"]')];
  if (links.length) {
    const sections = links
      .map((a) => document.getElementById(a.getAttribute('href').slice(1)))
      .filter((el) => !!el);
    let current = '';
    const setActive = (id) => {
      if (id === current) return;
      current = id;
      links.forEach((a) => a.classList.toggle('on', a.getAttribute('href').slice(1) === id));
    };
    let ticking = false;
    const update = () => {
      ticking = false;
      const line = 96;
      let active = sections.length ? sections[0].id : '';
      for (const s of sections) {
        if (s.getBoundingClientRect().top <= line) active = s.id;
        else break;
      }
      if (active) setActive(active);
    };
    const onScroll = () => {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>
