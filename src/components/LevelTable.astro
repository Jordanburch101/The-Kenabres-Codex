---
// Mirrors the prototype's `.tablewrap > table.levels` block used for the
// level-by-level progression tables (index.html, "Level-by-Level (1-20)"
// sections of the Wenduag / Demon Slayer builds).
import Prose from './Prose.astro';
const { levels } = Astro.props; // build.data.levels
const { headers, rows, note } = levels;
---
<section class="blk">
  <p class="eyebrow">Progression</p>
  <h2 class="h">Level-by-Level (1&ndash;20)</h2>
  {note && <Prose text={note} class="dim" />}
  <div class="tablewrap">
    <table class="levels">
      <thead>
        <tr>{headers.map((h) => <th>{h}</th>)}</tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td class="lv">{row.lv}</td>
            {row.cells.map((cell) => (
              <td><Prose as="span" text={cell} /></td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
